# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/bugbucket?schema=public"

# NextAuth.js Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# OAuth Providers (Optional)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# File Upload Configuration
# Use 'local' for development or 's3' for production
UPLOAD_PROVIDER="local"
UPLOAD_MAX_SIZE=10485760  # 10MB in bytes

# S3 Configuration (if using S3)
S3_BUCKET_NAME=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""  # Optional, for S3-compatible services like MinIO

# Email Configuration (for notifications)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@bugbucket.dev"

# Application Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Bug Bucket"

# Feature Flags
ENABLE_EMAIL_NOTIFICATIONS="false"
ENABLE_GITHUB_AUTH="false"
